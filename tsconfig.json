{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",       // Keep source files organized
    "outDir": "./dist",       // Emit compiled JS + d.ts here

    // Environment Settings
    "module": "nodenext",     // Good for modern Node + ESM
    "target": "ES2020",       // Slightly safer than esnext for npm consumers
    "lib": ["ES2020"],        // Standard library features
    "types": [],              // Keep empty unless you add @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options (optional, but recommended for libraries)
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // Recommended Options
    "strict": true,
    "verbatimModuleSyntax": true,   // Keep this for type-only imports
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src", "tests/playground.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
